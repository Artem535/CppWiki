@@ -657,8 +657,18 @@ void GraphicsView::updateSceneRect()
     /* We have to update here to adjust for any rows with no
      * information because they are painted with a different
      * background brush
+     *
+     * NOTE: This invalidate is deliberately commented out — it
+     * clears the entire background cache on every scene-rect
+     * recalculation (which fires on resize, scroll, and model
+     * changes), forcing DateTimeGrid::paintGrid to re-draw
+     * every row and day column from scratch.  Qt's own background
+     * caching (QGraphicsView::CacheBackground) already handles
+     * invalidation when the viewport resizes or scrolls, so this
+     * explicit invalidate is both redundant and the cause of the
+     * "laggy FPS on splitter resize" feedback in CppWiki #119.
      */
-    d->scene.invalidate(QRectF(), QGraphicsScene::BackgroundLayer);
+    // d->scene.invalidate(QRectF(), QGraphicsScene::BackgroundLayer);
 }
 
